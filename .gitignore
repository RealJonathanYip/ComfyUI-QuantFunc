# Python bytecode
__pycache__/
*.pyc

# Dynamic libraries (all platforms)
*.dll
*.so
*.dylib

# Static libraries (all platforms)
*.lib
*.a

# Keep bin directory structure but ignore libraries
# config.json and other non-binary files are still tracked

bin/linux/resource_cache.json
bin/windows/resource_cache.json
# Local Claude Code settings — never publish
.claude/

# SHA-256 integrity verify: runtime cache + heal-state (per-version manifest cache + marker)
bin/*/verify-*.json
bin/*/verify.state
